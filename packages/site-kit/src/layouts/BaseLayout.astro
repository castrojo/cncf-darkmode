---
import { antiFlashScript } from '../lib/theme';
import SiteSwitcher from '../components/SiteSwitcher.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import KeyboardHelp from '../components/KeyboardHelp.astro';
import '../styles/layout.css';

interface Props {
  title: string;
  description?: string;
  activeSite: 'projects' | 'members';
  noIndex?: boolean;
  siteTitle?: string;
  homeHref?: string;
  tabCount?: number;
  showHelpButton?: boolean;
}

const {
  title,
  description,
  activeSite,
  noIndex = false,
  siteTitle = 'CNCF',
  homeHref = '/',
  tabCount = 9,
  showHelpButton = true,
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noIndex && <meta name="robots" content="noindex" />}
    <script is:inline set:html={antiFlashScript} />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <div class="header-inner">
          <div class="header-left">
            <div class="logo-title">
              <span class="cncf-logo-wrapper" aria-hidden="true">
                <img src={`${base}/cncf-icon-color.svg`} alt="CNCF" class="logo-light" width="42" height="42" />
                <img src={`${base}/cncf-icon-white.svg`} alt="CNCF" class="logo-dark" width="42" height="42" />
              </span>
              <div class="title-block">
                <h1 class="site-title"><a href={homeHref} class="home-link">{siteTitle}</a></h1>
              </div>
            </div>
          </div>

          <div class="nav-group">
            <SiteSwitcher activeSite={activeSite} />
            <slot name="header-nav" />
          </div>

          <div class="header-actions">
            <ThemeToggle />
            {showHelpButton && (
              <button id="help-button" class="icon-button" aria-label="Keyboard shortcuts (?)" title="Keyboard shortcuts (?)">?</button>
            )}
            <slot name="header-actions" />
          </div>
        </div>
        <slot name="section-nav" />
      </div>
    </header>

    <main class="container">
      <div class="page-layout">
        <aside class="sidebar">
          <slot name="sidebar" />
        </aside>
        <div class="main-content">
          <slot />
        </div>
      </div>
    </main>

    <slot name="footer" />
    <KeyboardHelp tabCount={tabCount} />
    <div id="kbd-live-region" aria-live="polite" aria-atomic="true" class="sr-only"></div>
    <slot name="body-end" />

    <script>
      document.getElementById('help-button')?.addEventListener('click', () => {
        document.getElementById('keyboard-help-modal')?.classList.add('visible');
        document.getElementById('keyboard-help-backdrop')?.classList.add('visible');
      });

      const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
      const searchClear = document.getElementById('search-clear') as HTMLButtonElement | null;
      if (searchInput && searchClear) {
        searchInput.addEventListener('input', () => {
          searchClear.style.display = searchInput.value ? 'flex' : 'none';
        });
        searchClear.addEventListener('click', () => {
          searchInput.value = '';
          searchClear.style.display = 'none';
          searchInput.dispatchEvent(new Event('input'));
          searchInput.focus();
        });
      }
    </script>
  </body>
</html>

<style>
  .logo-light { display: block; }
  .logo-dark { display: none; }
  [data-theme='dark'] .logo-light { display: none; }
  [data-theme='dark'] .logo-dark { display: block; }

  .icon-button {
    background: none;
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
