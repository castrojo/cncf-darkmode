---
// BaseLayout.astro — Shared page scaffold for all CNCF trilogy sites.
//
// Slots:
//   head     — extra <head> content (meta tags, canonical URLs, structured data)
//   sidebar  — left sidebar content (site nav, InfoBox, KubeConBanner)
//   default  — main content area
//
// Props:
//   title       — <title> content (required)
//   description — meta description
//   activeSite  — which site pill is active in SiteSwitcher
//   noIndex     — set true to add noindex meta

import { antiFlashScript } from '../lib/theme';
import SiteSwitcher from '../components/SiteSwitcher.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import KeyboardHelp from '../components/KeyboardHelp.astro';

interface Props {
  title: string;
  description?: string;
  activeSite: 'people' | 'projects' | 'endusers';
  noIndex?: boolean;
}

const { title, description, activeSite, noIndex = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noIndex && <meta name="robots" content="noindex" />}

    <!-- Anti-flash: resolve theme before first paint to avoid FOUC -->
    <script is:inline set:html={antiFlashScript} />

    <!-- Shared base styles -->
    <link rel="stylesheet" href="/styles/variables-base.css" />
    <link rel="stylesheet" href="/styles/layout.css" />

    <!-- Extra head content injected by sites -->
    <slot name="head" />
  </head>
  <body>
    <!-- Screen reader live region for announcements (theme changes, etc.) -->
    <div id="kbd-live-region" aria-live="polite" aria-atomic="true" class="sr-only"></div>

    <header class="site-header">
      <div class="container">
        <div class="header-inner">
          <div class="header-left">
            <a class="cncf-logo-wrapper" href="https://cncf.io" target="_blank" rel="noopener noreferrer" aria-label="CNCF home">
              <img src="/cncf-logo.svg" alt="CNCF" width="42" height="42" />
            </a>
            <h1 class="site-title">
              <a href="/">
                <slot name="site-title">CNCF</slot>
              </a>
            </h1>
          </div>

          <nav class="nav-group" aria-label="Site navigation">
            <SiteSwitcher activeSite={activeSite} />
            <ThemeToggle />
          </nav>
        </div>

        <!-- Section nav (tabs) — injected by individual pages -->
        <slot name="section-nav" />
      </div>
    </header>

    <main class="container main-layout">
      <aside class="sidebar" aria-label="Sidebar">
        <slot name="sidebar" />
      </aside>

      <section class="main-content" aria-label="Main content">
        <slot />
      </section>
    </main>

    <KeyboardHelp />
  </body>
</html>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .main-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2rem;
    padding-top: 1.5rem;
    padding-bottom: 3rem;
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .main-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      order: 2; /* Push sidebar below content on mobile */
    }

    .main-content {
      order: 1;
    }
  }
</style>
