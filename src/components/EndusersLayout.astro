---
import BaseLayout from './BaseLayout.astro';
import KubeConBanner from './KubeConBanner.astro';
import InfoBox from './InfoBox.astro';
import { getActiveBanners } from '../lib/banners';
import archData from '../data/members/architectures.json';
import '../styles/variables.css';
import '../styles/members/cards.css';

interface Props {
  title: string;
  description?: string;
  memberCount?: number;
  totalFunding?: number;
  industries?: string[];
  countries?: string[];
  platinumCount?: number;
  goldCount?: number;
  silverCount?: number;
  archCount?: number;
  archRefTypes?: string[];
  archIndustryList?: string[];
  archIndustryCount?: number;
  archProjectCount?: number;
}

const {
  title,
  description = 'CNCF End Users and member organizations',
  memberCount = 0,
  totalFunding = 0,
  industries = [],
  countries = [],
  platinumCount = 0,
  goldCount = 0,
  silverCount = 0,
  archCount = 0,
  archRefTypes = [],
  archIndustryList = [],
  archIndustryCount = 0,
  archProjectCount = 0,
} = Astro.props;

const banners = await getActiveBanners();
const base = import.meta.env.BASE_URL;
const includeEmbeddedData = import.meta.env.DEV;
---

<BaseLayout
  title={title}
  description={description}
  activeSite="members"
  siteTitle="CNCF End Users"
  homeHref={base || '/'}
  tabCount={6}
>
  <Fragment slot="head">
    <link rel="icon" href={`${base}/cncf-icon-color.svg`} type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="CNCF End Users Feed" href={`${base}/feed.xml`} />
  </Fragment>

  <div slot="header-nav" class="search-wrapper">
    <input id="search-input" class="search-input" type="text" placeholder="Search end users... (/)" aria-label="Search end users" />
    <span class="search-count" id="search-count"></span>
    <button id="search-clear" class="search-clear" aria-label="Clear search" title="Clear search">✕</button>
  </div>

  <nav slot="section-nav" class="section-nav" aria-label="Filter by tier">
    <button class="section-link active" data-tab="everyone">Everyone</button>
    <button class="section-link" data-tab="platinum">Platinum</button>
    <button class="section-link" data-tab="gold">Gold</button>
    <button class="section-link" data-tab="silver">Silver</button>
    <button class="section-link" data-tab="academic">Academic &amp; Nonprofit</button>
    <button class="section-link" data-tab="architectures">Reference Architectures{archCount > 0 && <span class="tab-count">{archCount}</span>}</button>
  </nav>

  <Fragment slot="sidebar">
    <InfoBox
      title="About CNCF End Users"
      description="Organizations that use cloud native technologies and support CNCF."
      links={[
        { text: 'CNCF Landscape', url: 'https://landscape.cncf.io', external: true },
        { text: 'Become a Member', url: 'https://www.cncf.io/about/join/', external: true },
        { text: 'End Users Feed (RSS)', url: `${base}/feed.xml`, rss: true },
        { text: 'Report an issue', url: 'https://github.com/castrojo/cncf-darkmode/issues', external: true },
      ]}
    />
    {banners.length > 0 && <KubeConBanner banners={banners} />}

    <div id="member-sidebar-sections">
      {industries.length > 0 && (
        <div class="filter-box">
          <h2 class="sidebar-heading">Filter by Industry</h2>
          <select id="industry-filter" class="category-select" aria-label="Filter by industry">
            <option value="">All industries</option>
            {industries.map(ind => <option value={ind}>{ind}</option>)}
          </select>
        </div>
      )}
      <div class="filter-box">
        <h2 class="sidebar-heading">Filter by Region</h2>
        <select id="region-filter" class="category-select" aria-label="Filter by region">
          <option value="">All regions</option>
          {countries.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>
      <div class="stats-box">
        <h2 class="sidebar-heading">End Users</h2>
        <div class="stat-row"><span class="stat-label">Total members</span><span class="stat-value" id="stat-total">{memberCount}</span></div>
        <div class="stat-row"><span class="stat-label">Platinum</span><span class="stat-value">{platinumCount}</span></div>
        <div class="stat-row"><span class="stat-label">Gold</span><span class="stat-value">{goldCount}</span></div>
        <div class="stat-row"><span class="stat-label">Silver</span><span class="stat-value">{silverCount}</span></div>
        <div class="stat-row"><span class="stat-label">Showing</span><span class="stat-value" id="stat-showing"></span></div>
        {totalFunding > 0 && (
          <div class="stat-row"><span class="stat-label">Total funding</span><span class="stat-value">${Math.round(totalFunding / 1e9)}B+</span></div>
        )}
      </div>
    </div>

    <div id="arch-sidebar-sections" style="display:none">
      {archRefTypes.length > 0 && (
        <div class="filter-box">
          <h2 class="sidebar-heading">Filter by Type</h2>
          <select id="arch-reftype-filter" class="category-select" aria-label="Filter by architecture type">
            <option value="">All types</option>
            {archRefTypes.map(t => <option value={t}>{t}</option>)}
          </select>
        </div>
      )}
      {archIndustryList.length > 0 && (
        <div class="filter-box">
          <h2 class="sidebar-heading">Filter by Industry</h2>
          <select id="arch-industry-filter" class="category-select" aria-label="Filter by industry">
            <option value="">All industries</option>
            {archIndustryList.map(ind => <option value={ind}>{ind}</option>)}
          </select>
        </div>
      )}
      {archCount > 0 && (
        <div class="stats-box" id="arch-stats-box">
          <h2 class="sidebar-heading">Reference Architectures</h2>
          <div class="stat-row"><span class="stat-label">Architectures</span><span class="stat-value">{archCount}</span></div>
          {archIndustryCount > 0 && <div class="stat-row"><span class="stat-label">Industries</span><span class="stat-value">{archIndustryCount}</span></div>}
          {archProjectCount > 0 && <div class="stat-row"><span class="stat-label">CNCF Projects</span><span class="stat-value">{archProjectCount}</span></div>}
        </div>
      )}
    </div>
  </Fragment>

  <slot name="heroes" />
  <div id="members-grid" class="members-grid">
    <slot />
  </div>
  <div id="arch-grid" class="arch-grid" style="display:none">
    <slot name="architectures" />
  </div>
  <div id="no-results" class="no-results" style="display:none">No members match your search.</div>

  <Fragment slot="body-end">
    {includeEmbeddedData && (
      <script type="application/json" id="arch-data" set:html={JSON.stringify(Object.fromEntries((archData as any[]).map((a: any) => [a.slug, a])))} />
    )}
    <slot name="body-end" />

    <dialog id="arch-modal" aria-modal="true" aria-labelledby="arch-modal-title">
      <div class="arch-modal-dialog">
        <button class="arch-modal-close" id="arch-modal-close" aria-label="Close architecture details">✕</button>
        <div class="arch-modal-content" id="arch-modal-content"></div>
        <div class="arch-modal-footer">
          <a class="arch-modal-ext-link" id="arch-modal-ext-link" href="#" target="_blank" rel="noopener noreferrer">
            View on CNCF →
          </a>
        </div>
      </div>
    </dialog>
  </Fragment>
</BaseLayout>

<style is:global>
  .heroes-section { margin-bottom: 1.5rem; }
  .stats-box { background: var(--color-bg-default); border: 1px solid var(--color-border-default); border-radius: 6px; padding: 1rem; }
  .sidebar-heading { font-size: 0.875rem; font-weight: 600; margin: 0 0 0.75rem; }
  .stat-row { display: flex; justify-content: space-between; align-items: center; padding: 0.25rem 0; font-size: 0.875rem; }
  .stat-label { color: var(--color-text-secondary); }
  .stat-value { font-weight: 600; color: var(--color-text-primary); }
  .members-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
  .no-results { text-align: center; padding: 3rem 1rem; color: var(--color-text-secondary); grid-column: 1 / -1; }
  .filter-box { background: var(--color-bg-default); border: 1px solid var(--color-border-default); border-radius: 6px; padding: 1rem; }
  .category-select { width: 100%; padding: 0.375rem 0.5rem; border: 1px solid var(--color-border-default); border-radius: 6px; background: var(--color-bg-secondary); color: var(--color-text-primary); font-size: 0.875rem; cursor: pointer; }
  .tab-count { display: inline-block; font-size: 0.7rem; font-weight: 600; background: var(--color-bg-secondary, #f6f8fa); color: var(--color-text-secondary, #57606a); border: 1px solid var(--color-border-default, #d0d7de); border-radius: 999px; padding: 1px 6px; margin-left: 4px; line-height: 1.4; vertical-align: middle; }
  .arch-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.25rem; }
  .arch-intro { padding: 0.75rem 0 1rem; color: var(--color-text-secondary); font-size: 0.9rem; }
  .arch-empty { text-align: center; padding: 3rem 1rem; color: var(--color-text-secondary); }
  .keyboard-focused { outline: 2px solid var(--color-cncf-blue); outline-offset: 2px; }

  #arch-modal { padding: 0; border: none; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.24); max-width: 780px; width: 94vw; max-height: 90vh; overflow: hidden; }
  #arch-modal::backdrop { background: rgba(0,0,0,0.5); backdrop-filter: blur(2px); }
  .arch-modal-dialog { display: flex; flex-direction: column; height: 100%; max-height: 90vh; background: var(--color-bg-default); color: var(--color-text-primary); overflow-y: auto; }
  .arch-modal-close { position: sticky; top: 0.75rem; left: calc(100% - 2.5rem); z-index: 10; background: var(--color-bg-secondary); border: 1px solid var(--color-border-default); border-radius: 50%; width: 2rem; height: 2rem; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; }
  .arch-modal-content { padding: 1.25rem 1.5rem; flex: 1; }
  .arch-modal-footer { padding: 1rem 1.5rem; border-top: 1px solid var(--color-border-default); display: flex; justify-content: flex-end; }
  .arch-modal-ext-link { display: inline-block; padding: 0.5rem 1rem; background: var(--color-cncf-blue); color: white; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.875rem; }
</style>
