---
/**
 * PeopleLightbox.astro — Dialog shell for the People section person detail lightbox.
 *
 * CSS namespace: plb-*  (NOT plb2-* which belongs to ProjectLightbox)
 *
 * Usage:
 *   1. Include <PeopleLightbox /> once in PeopleLayout.astro.
 *   2. In a client-side <script>, call:
 *        import { initPersonLightbox, openPersonLightbox } from '../../lib/people/person-lightbox';
 *        initPersonLightbox();
 *        card.addEventListener('click', () => openPersonLightbox(personData, projectDetails, base));
 *
 * Content is populated dynamically by person-lightbox.ts after the dialog opens.
 * The dialog itself carries:
 *   - aria-modal="true" for screen-reader modal semantics
 *   - aria-labelledby="person-modal-title" (rendered into #person-modal-content by the JS)
 *   - focus management via native <dialog> showModal() / close()
 *   - Escape key handled natively by <dialog>
 *   - Backdrop click handled by initPersonLightbox()
 */
---

<dialog
  id="person-modal"
  class="plb-dialog"
  aria-modal="true"
  aria-labelledby="person-modal-title"
>
  <div class="plb-dialog-box" role="document">
    <div class="plb-dialog-toolbar">
      <button
        id="person-modal-close"
        class="plb-close-btn"
        aria-label="Close person details"
        type="button"
      >✕</button>
    </div>
    <div id="person-modal-content" class="plb-dialog-content">
      <!-- Populated by person-lightbox.ts after dialog opens -->
    </div>
  </div>
</dialog>

<style>
/* ─── plb-* namespace: People Lightbox dialog shell ─────────────────────── */
/* Scoped to this component. Does NOT conflict with plb2-* (ProjectLightbox). */

/* Backdrop / overlay */
.plb-dialog {
  position: fixed;
  inset: 0;
  margin: auto;
  padding: 0;
  border: none;
  background: transparent;
  max-width: 100vw;
  max-height: 100dvh;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.plb-dialog::backdrop {
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(2px);
}

/* Not-open state: hide without display:none so dialog API still works */
.plb-dialog:not([open]) {
  display: none;
}

/* Inner content box */
.plb-dialog-box {
  position: relative;
  background: var(--color-bg-default, #ffffff);
  border: 1px solid var(--color-border-default, #d0d7de);
  border-radius: 12px;
  width: min(720px, 94vw);
  max-height: min(88dvh, 820px);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.24);
}

/* Toolbar row (close button) */
.plb-dialog-toolbar {
  display: flex;
  justify-content: flex-end;
  padding: 0.5rem 0.75rem;
  border-bottom: 1px solid var(--color-border-default, #d0d7de);
  background: var(--color-bg-secondary, #f6f8fa);
  flex-shrink: 0;
}

.plb-close-btn {
  background: none;
  border: 1px solid var(--color-border-default, #d0d7de);
  border-radius: 6px;
  padding: 0.25rem 0.6rem;
  font-size: 0.875rem;
  color: var(--color-text-secondary, #57606a);
  cursor: pointer;
  line-height: 1;
  transition: background 0.15s, border-color 0.15s;
}
.plb-close-btn:hover {
  background: var(--color-bg-tertiary, #eaeef2);
  border-color: var(--color-text-muted, #656d76);
  color: var(--color-text-primary, #24292f);
}
.plb-close-btn:focus-visible {
  outline: 2px solid var(--color-accent-emphasis, #0969da);
  outline-offset: 2px;
}

/* Scrollable content area */
.plb-dialog-content {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 0;
}
</style>

<style is:global>
/* ─── plb-* namespace: People Lightbox content styles ───────────────────── */
/* These are global because the HTML is injected by person-lightbox.ts JS,   */
/* not rendered by Astro, so scoped styles won't reach it.                   */

/* ── Header accent bar + layout ─────────────────────────────────────────── */
.plb-header {
  position: relative;
  padding: 1.25rem 1.5rem 1rem;
}

.plb-accent-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--plb-accent, #888);
  border-radius: 0;
}

.plb-header-inner {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

/* ── Avatar ─────────────────────────────────────────────────────────────── */
.plb-avatar-link {
  flex-shrink: 0;
  display: block;
  border-radius: 50%;
  text-decoration: none;
  transition: opacity 0.15s;
}
.plb-avatar-link:hover { opacity: 0.85; }

.plb-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--color-border-default, #d0d7de);
  background: var(--color-bg-secondary, #f6f8fa);
}

.plb-avatar--placeholder {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: color-mix(in srgb, var(--plb-accent, #888) 15%, transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  font-weight: 700;
  color: var(--plb-accent, #888);
  border: 2px solid color-mix(in srgb, var(--plb-accent, #888) 30%, transparent);
}

/* ── Identity block ──────────────────────────────────────────────────────── */
.plb-identity {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.plb-name {
  margin: 0;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--color-text-primary, #24292f);
  line-height: 1.2;
}

.plb-name a {
  color: inherit;
  text-decoration: none;
}
.plb-name a:hover { text-decoration: underline; }

.plb-handle {
  font-size: 0.875rem;
  color: var(--color-text-secondary, #57606a);
  text-decoration: none;
}
.plb-handle:hover { text-decoration: underline; color: var(--color-accent-emphasis, #0969da); }

.plb-pronouns {
  font-size: 0.8125rem;
  color: var(--color-text-muted, #656d76);
}

.plb-meta-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  font-size: 0.8125rem;
}

.plb-company {
  color: var(--color-text-secondary, #57606a);
  text-decoration: none;
}
a.plb-company:hover { text-decoration: underline; color: var(--color-accent-emphasis, #0969da); }

.plb-location {
  color: var(--color-text-muted, #656d76);
}
.plb-meta-row .plb-company + .plb-location::before {
  content: '·';
  margin-right: 0.5rem;
  color: var(--color-border-default, #d0d7de);
}

.plb-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  margin-top: 0.25rem;
}

.plb-badge {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  white-space: nowrap;
}

/* ── Program logo (top-right of header) ─────────────────────────────────── */
.plb-program-logo {
  width: 52px;
  height: 52px;
  object-fit: contain;
  flex-shrink: 0;
}

/* ── Body section ────────────────────────────────────────────────────────── */
.plb-body {
  padding: 0 1.5rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* ── Bio ─────────────────────────────────────────────────────────────────── */
.plb-bio {
  margin: 0;
  font-size: 0.875rem;
  line-height: 1.6;
  color: var(--color-text-secondary, #57606a);
}

/* ── Stats row ───────────────────────────────────────────────────────────── */
.plb-stats-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.plb-stat-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.3rem 0.625rem;
  background: var(--color-bg-secondary, #f6f8fa);
  border: 1px solid var(--color-border-default, #d0d7de);
  border-radius: 6px;
  font-size: 0.8rem;
}

.plb-stat-icon {
  font-size: 0.9rem;
  line-height: 1;
}

.plb-stat-val {
  font-weight: 700;
  color: var(--color-text-primary, #24292f);
}

.plb-stat-label {
  font-size: 0.7rem;
  color: var(--color-text-muted, #656d76);
}

/* ── Social links row ────────────────────────────────────────────────────── */
.plb-social-links {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.plb-social-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 6px;
  border: 1px solid var(--color-border-default, #d0d7de);
  color: var(--color-text-secondary, #57606a);
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}

.plb-social-link:hover {
  background: var(--color-bg-secondary, #f6f8fa);
  border-color: var(--color-text-muted, #656d76);
  color: var(--color-text-primary, #24292f);
}
.plb-social-link:focus-visible {
  outline: 2px solid var(--color-accent-emphasis, #0969da);
  outline-offset: 2px;
}

/* ── Section heading ─────────────────────────────────────────────────────── */
.plb-section {
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.plb-section-heading {
  margin: 0;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--color-text-muted, #656d76);
}

/* ── Projects grid ───────────────────────────────────────────────────────── */
.plb-projects-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

/* Project chip (link) */
.plb-project-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.3rem 0.625rem 0.3rem 0.375rem;
  border-radius: 6px;
  border: 1px solid var(--color-border-default, #d0d7de);
  background: var(--color-bg-secondary, #f6f8fa);
  text-decoration: none;
  color: var(--color-text-primary, #24292f);
  font-size: 0.8125rem;
  font-weight: 500;
  transition: background 0.15s, border-color 0.15s;
  max-width: 200px;
}
.plb-project-chip:hover {
  background: var(--color-bg-tertiary, #eaeef2);
  border-color: var(--color-text-muted, #656d76);
}
.plb-project-chip:focus-visible {
  outline: 2px solid var(--color-accent-emphasis, #0969da);
  outline-offset: 2px;
}

.plb-project-logo {
  width: 20px;
  height: 20px;
  object-fit: contain;
  flex-shrink: 0;
  border-radius: 3px;
}

.plb-project-logo--fallback {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  border-radius: 3px;
  background: var(--color-bg-tertiary, #eaeef2);
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--color-text-muted, #656d76);
  flex-shrink: 0;
}

.plb-maturity-dot {
  display: inline-block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  flex-shrink: 0;
}

.plb-project-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 480px) {
  .plb-header-inner {
    flex-wrap: wrap;
  }

  .plb-avatar,
  .plb-avatar--placeholder {
    width: 60px;
    height: 60px;
    font-size: 1.5rem;
  }

  .plb-name {
    font-size: 1.1rem;
  }

  .plb-program-logo {
    display: none;
  }
}

/* ── Dark mode overrides ─────────────────────────────────────────────────── */
[data-theme="dark"] .plb-dialog-box {
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
}
</style>
