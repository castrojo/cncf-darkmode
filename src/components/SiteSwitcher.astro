---
interface Props {
  activeSite: 'projects' | 'members' | 'people';
}
const { activeSite } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sites = [
  { key: 'projects', label: 'Projects',  url: `${base}/` },
  { key: 'members',  label: 'End Users', url: `${base}/members/` },
  { key: 'people',   label: 'People',    url: `${base}/people/` },
];
---
<nav class="site-switcher" aria-label="CNCF Landscape sections">
  {sites.map(site => (
    site.key === activeSite
      ? <span class="switcher-pill active" aria-current="page">{site.label}</span>
      : <a class="switcher-pill" href={site.url}>{site.label}</a>
  ))}
</nav>

<style>
  .site-switcher {
    display: inline-flex;
    gap: 0;
    background: var(--color-bg-tertiary, #eaeef2);
    border: 1px solid var(--color-border-default, #d0d7de);
    border-radius: 8px;
    padding: 2px;
  }
  .switcher-pill {
    padding: 0.3rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary, #57606a);
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.15s ease;
  }
  .switcher-pill.active {
    color: #ffffff;
    background: #0060CC;
    box-shadow: 0 1px 3px rgba(0, 96, 204, 0.3);
    font-weight: 600;
  }
  .switcher-pill:hover:not(.active) {
    color: var(--color-text-primary, #24292f);
    background: var(--color-bg-default, #ffffff);
  }
</style>
